---
import { getCollection } from "astro:content";

const cocktails = await getCollection('cocktails');
---

<header class="border-4 container flex flex-col gap-4 sm:gap-2 mb-10 mt-0 md:mt-4 p-2">
    <div class="flex flex-wrap gap-2 grow sm:grow-0 items-start justify-between sm:justify-start">
        <a class="font-black hover:text-blue-800 text-4xl md:text-8xl" href="/">Cocktails</a>
        <span class="bg-blue-900 px-2 py-1 hover:bg-blue-800 text-white">{`${cocktails.length} disponibles`}</span>
    </div>
    <a class="font-bold hover:text-blue-800 text-2xl md:text-3xl text-balance" href="/random">
        Laissez-vous tenter par l'aventure avec un cocktail au hasard !
    </a>
</header>
