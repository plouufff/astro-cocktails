---
import { getCollection } from "astro:content";

const cocktails = await getCollection('cocktails');
---

<header class="container flex gap-4 items-center justify-between mx-auto my-2 md:my-4 p-2 md:p-4">
    <div class="flex gap-2 items-start ">
      <a class="font-bold text-2xl md:text-4xl" href="/">&#127865;Cocktails</a>
        <span class="bg-primary px-2 py-1 rounded text-xs text-white">{`${cocktails.length} recettes`}</span>
    </div>
    <a
        class="text-primary font-bold border-2 border-primary hover:bg-primary-dark hover:border-primary-dark hover:cursor-pointer hover:text-white p-1 md:p-2 rounded text-center"
        href="/random"
    >
        &#127922; Au hasard !
    </a>
</header>
