---
import { getCollection } from "astro:content";

import Badge from "./Badge.astro";

const cocktails = await getCollection('cocktails');
---

<header class="container flex items-center justify-between mb-10 mt-0 md:mt-4">
    <div class="flex gap-2 items-center">
        <a class="font-bold text-4xl text-blue-950" href="/">Cocktails !</a>
        <Badge label={`${cocktails.length} disponibles`}/>
    </div>
    <a class="bg-blue-500 hover:bg-blue-600 text-white rounded p-2" href="/random">Un cocktail au hasard</a>
</header>